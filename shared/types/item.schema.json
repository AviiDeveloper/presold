{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://presold.app/schemas/item.json",
  "title": "Item",
  "description": "Universal item data output by identify-item (Prompt 1, see docs/ai-prompts.md). Every identifiable field is nullable; the model returns nulls and confidence:0 when the photo contains no identifiable item.",
  "type": "object",
  "required": ["title", "description", "brand", "category", "size", "color", "condition", "weight_grams_estimate", "confidence"],
  "properties": {
    "title": { "type": ["string", "null"], "maxLength": 60 },
    "description": { "type": ["string", "null"] },
    "brand": { "type": ["string", "null"] },
    "category": { "type": ["string", "null"] },
    "size": { "type": ["string", "null"] },
    "color": { "type": ["string", "null"] },
    "condition": {
      "type": ["string", "null"],
      "enum": ["new_with_tags", "new_without_tags", "very_good", "good", "satisfactory", null]
    },
    "weight_grams_estimate": { "type": ["integer", "null"], "minimum": 0 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
