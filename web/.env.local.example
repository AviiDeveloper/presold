# Public (exposed to browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# Server only (NEVER expose)
SUPABASE_SERVICE_ROLE_KEY=

# AI gateway — currently OpenRouter; swap back to Anthropic direct once
# billing is enabled. See docs/decisions/004-openrouter-temporary-ai-gateway.md
OPENROUTER_API_KEY=

# eBay (Marketplace Insights, production). Optional at runtime — the scanner
# degrades to comps=[] if these are absent. Apply at developer.ebay.com.
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_ENV=PRODUCTION
